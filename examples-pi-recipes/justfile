# --- Kitchen Sink ---

# 35. Full stack: safety + git + workflow + UI
ext-full:
    pi -e {{ext}}/safety/protected-paths.ts -e {{ext}}/safety/permission-gate.ts -e {{ext}}/safety/dirty-repo-guard.ts -e {{ext}}/git/git-checkpoint.ts -e {{ext}}/ui/notify.ts -e {{ext}}/ui/titlebar-spinner.ts -e {{ext}}/ui/inline-bash.ts -e {{ext}}/workflow/trigger-compact.ts -e {{ext}}/ui/tool-counter.ts -e {{ext}}/ui/theme-cycler.ts

# Open pi with one or more stacked extensions in a new terminal: fu open minimal tool-counter
open +exts:
    #!/usr/bin/env bash
    args=""
    for ext in {{exts}}; do
        args="$args -e {{ext}}/$ext.ts"
    done
    cmd="cd '$PWD' && pi$args"
    escaped="${cmd//\\/\\\\}"
    escaped="${escaped//\"/\\\"}"
    osascript -e "tell application \"Terminal\" to do script \"$escaped\""
