    pi -e {{ext}}/orchestration/agent-chain.ts -e {{ext}}/ui/theme-cycler.ts

# 14. Pi Pi: meta-agent that builds Pi agents with parallel expert research
ext-pi-pi:
    pi -e {{ext}}/orchestration/pi-pi.ts -e {{ext}}/ui/theme-cycler.ts

# 15. Session Replay: scrollable timeline overlay of session history (legit)
ext-session-replay:
    pi -e {{ext}}/ui/session-replay.ts -e {{ext}}/ui/minimal.ts

# 16. Theme cycler: Ctrl+X forward, Ctrl+Q backward, /theme picker
ext-theme-cycler:
    pi -e {{ext}}/ui/theme-cycler.ts -e {{ext}}/ui/minimal.ts

# 17. UV: redirect python/pip/poetry to uv equivalents
ext-uv:
    pi -e {{ext}}/workflow/uv.ts -e {{ext}}/ui/minimal.ts

# 18. Chart: inline matplotlib visualizations with uv-managed Python
ext-chart:
    pi -e {{ext}}/ui/chart.ts -e {{ext}}/workflow/uv.ts -e {{ext}}/ui/minimal.ts

# 19. Data analyst: structured analysis workspace with inline charts
analyst:
    pi -e {{ext}}/ui/chart.ts -e {{ext}}/workflow/uv.ts -e {{ext}}/ui/minimal.ts --append-system-prompt {{agents}}/analyst.md

# --- Safety & Git ---

# 20. Protected paths: block writes to .env, .git/, node_modules/
