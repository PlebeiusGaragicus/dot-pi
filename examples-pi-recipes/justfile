set dotenv-load := true

ext := justfile_directory() / "extensions"
agents := justfile_directory() / ".pi" / "agents"

default:
    @just --justfile {{justfile()}} --list

# 1. default pi
pi:
    pi

# Chat mode: pure conversation, no tools, no file access
chat:
    pi -e {{ext}}/workflow/chat.ts -e {{ext}}/ui/pure-focus.ts

# Vision: auto-switch to vision model when reading images
vision:
    pi -e {{ext}}/workflow/vision-switch.ts -e {{ext}}/ui/minimal.ts

# 2. Pure focus pi: strip footer and status line entirely
ext-pure-focus:
    pi -e {{ext}}/ui/pure-focus.ts

# 3. Minimal pi: model name + 10-block context meter
ext-minimal:
    pi -e {{ext}}/ui/minimal.ts -e {{ext}}/ui/theme-cycler.ts

# 4. Cross-agent pi: load commands from .claude/, .gemini/, .codex/ dirs
ext-cross-agent:
    pi -e {{ext}}/workflow/cross-agent.ts -e {{ext}}/ui/minimal.ts

# 5. Purpose gate pi: declare intent before working, persistent widget, focus the system prompt on the ONE PURPOSE for this agent
ext-purpose-gate:
    pi -e {{ext}}/workflow/purpose-gate.ts -e {{ext}}/ui/minimal.ts

# 6. Customized footer pi: Tool counter, model, branch, cwd, cost, etc.
ext-tool-counter:
    pi -e {{ext}}/ui/tool-counter.ts

# 7. Tool counter widget: tool call counts in a below-editor widget
ext-tool-counter-widget:
    pi -e {{ext}}/ui/tool-counter-widget.ts -e {{ext}}/ui/minimal.ts

# 8. Subagent widget: /sub <task> with live streaming progress
ext-subagent-widget:
    pi -e {{ext}}/orchestration/subagent-widget.ts -e {{ext}}/ui/pure-focus.ts -e {{ext}}/ui/theme-cycler.ts

# 9. TillDone: task-driven discipline -- define tasks before working
ext-tilldone:
    pi -e {{ext}}/workflow/tilldone.ts -e {{ext}}/ui/theme-cycler.ts

# 10. Agent team: dispatcher orchestrator with team select and grid dashboard
ext-agent-team:
    pi -e {{ext}}/orchestration/agent-team.ts -e {{ext}}/ui/theme-cycler.ts

# 11. System select: /system to pick an agent persona as system prompt
ext-system-select:
    pi -e {{ext}}/workflow/system-select.ts -e {{ext}}/ui/minimal.ts -e {{ext}}/ui/theme-cycler.ts

# 12. Launch with Damage-Control safety auditing
ext-damage-control:
    pi -e {{ext}}/safety/damage-control.ts -e {{ext}}/ui/minimal.ts -e {{ext}}/ui/theme-cycler.ts

# 13. Agent chain: sequential pipeline orchestrator
